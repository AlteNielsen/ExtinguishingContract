<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Style src="project:/Assets/Scenes/Utility/base.uss" />
    <ui:Style src="project:/Assets/Scenes/Common/main.uss" />
    <ui:Style src="project:/Assets/Scenes/Common/fonts.uss" />
    <ui:Style src="project:/Assets/Scenes/Unit/unit.uss" />

    <ui:VisualElement class="unit-card center-line">
        <ui:VisualElement class="abs-all bg-block" />
        <ui:VisualElement class="row">
            <ui:Label name="UnitCategory" class="serif-regular text-small color-white" text="消火戦車" />
            <ui:Label name="UnitName" class="serif-regular text-small color-white" text="「ゼーロウ」" />
        </ui:VisualElement>
        <ui:VisualElement class="unit-card-icon" >
            <ui:VisualElement name="UnitIcon" class="all unit-card-icon-not" />
            <ui:Button name="UnitSelector" class="abs-all button-initialize transparent" />
        </ui:VisualElement>
        <ui:Label name="UnitText" class="serif-regular text-small color-white" text="▼消火範囲▼" />
        <ui:VisualElement class="row" >
            <ui:VisualElement class="unit-level-button" >
                <ui:VisualElement class="all bg-darkgray semi-transparent" />
                <ui:VisualElement name="LevelSelectorBG" class="abs-all on-button bg-darkgray" />
                <ui:Label name="LevelSelectorLabel" class="abs-all serif-regular text-mid color-white text-adjust-alpha text-set-center" text="Ⅰ" />
                <ui:Button name="LevelSelector" class="abs-all button-initialize transparent" />
            </ui:VisualElement>
            <ui:VisualElement class="unit-level-button" >
                <ui:VisualElement class="all bg-darkgray semi-transparent" />
                <ui:VisualElement name="LevelSelectorBG" class="abs-all on-button bg-darkgray" />
                <ui:Label name="LevelSelectorLabel" class="abs-all serif-regular text-mid color-white text-adjust-alpha text-set-center" text="Ⅱ" />
                <ui:Button name="LevelSelector" class="abs-all button-initialize transparent" />
            </ui:VisualElement>
            <ui:VisualElement class="unit-level-button" >
                <ui:VisualElement class="all bg-darkgray semi-transparent" />
                <ui:VisualElement name="LevelSelectorBG" class="abs-all on-button bg-darkgray" />
                <ui:Label name="LevelSelectorLabel" class="abs-all serif-regular text-mid color-white text-adjust-alpha text-set-center" text="Ⅲ" />
                <ui:Button name="LevelSelector" class="abs-all button-initialize transparent" />
            </ui:VisualElement>
            <ui:VisualElement class="unit-level-button" >
                <ui:VisualElement class="all bg-darkgray semi-transparent" />
                <ui:VisualElement name="LevelSelectorBG" class="abs-all on-button bg-darkgray" />
                <ui:Label name="LevelSelectorLabel" class="abs-all serif-regular text-mid color-white text-adjust-alpha text-set-center" text="Ⅳ" />
                <ui:Button name="LevelSelector" class="abs-all button-initialize transparent" />
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement class="plank-line-mid" />
        <ui:VisualElement name="UnitRange" class="range-grid center-line center-row">
            <ui:VisualElement class="grid-tile" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile" />
            <ui:VisualElement class="grid-tile" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile" />
            <ui:VisualElement class="grid-tile" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-on" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-on" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
            <ui:VisualElement class="grid-tile grid-tile-on" />
            <ui:VisualElement class="grid-tile grid-tile-unit" />
            <ui:VisualElement class="grid-tile grid-tile-on" />
            <ui:VisualElement class="grid-tile grid-tile-off" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>