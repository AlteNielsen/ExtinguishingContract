.sector-image{
    background-image: url('project:/Assets/Textures/damu2.png');
    -unity-background-scale-mode: scale-and-crop;
}

.upper-screen{
    width: 95%;
    height: 8%;
    left: 2.5%;
    top: 1.5%;
}

.lower-screen{
    width: 95%;
    height: 85%;
    left: 2.5%;
    top: 5%;
}

.left-colomn{
    width: 15%;
    height: 100%;
}

.line-horizontal{
    top:20%;
    height: 5px;
    width: 5%;
}

.center-colomn{
    top: 30px;
    width: 70%;
    height: 90%;
}

.right-colomn{
    width: 8%;
    height: 100%;
}

.block-button{
    width: 240px;
    height: 80px;
}

.indicator-button{
    width: 375px;
    height: 150px
}

.indicator-icon{
    height: 100%;
    width: 100%;
    background-image: url('project:/Assets/Textures/square_test_icon.png');
    -unity-background-scale-mode: scale-to-fit;
    background-position-x: left;
}

.map-button{
    width: 120px;
    height: 80px;
}

.map-button-tex-off{
    background-image: url('project:/Assets/Textures/map_button_icon.png');
}

.map-button-tex-on{
    background-image: url('project:/Assets/Textures/map_button_icon_on.png');
}

.decide-button{
    width: 300px;
    height: 80px;
}

.decide-button-txt{
    top: -6px;
}

.water-gauge{
    height: 740px;
    width: 100px;
}

.water-gauge-plank{
    background-color: #505050;
    opacity: 0.5;
    height: 40%;
    width: 100%
}

.water-gauge-add{
    background-color: #0084ff;
    height: 30%;
    width: 100%
}

.water-gauge-pool{
    background-color: #003899;
    height: 30%;
    width: 100%
}

.bg-block{
    background-color: black;
    opacity: 0.8;
    border-width: 1px;
    border-color: var(--color-red);
}

.text-offset-alpha{
    left: 30px;
}

.text-offset-beta{
    width: 975px;
}

.plank-alpha{
    width: 55%;
}

.plank-beta{
    width: 80px;
}

.return-button{
    width: 270px;
    height: 80px;
}

.return-button-icon{
    left: -30%;
    background-image: url('project:/Assets/Textures/return_icon.png');
    -unity-background-scale-mode: scale-to-fit;
}

.contract-memo{
    width: 400px;
    height: 80px;
}

.contract-memo-logo{
    top: 2px;
    width: 75px;
    height: 75px;
    background-image: url('project:/Assets/Textures/logo.png');
    -unity-background-scale-mode: scale-to-fit;
}

.contract-memo-id{
    position: absolute;
    top: -15%;
}

.contract-memo-grade{
    position: absolute;
    top: 20%;
}

.block-button-text-offset{
    top: -4px;
}

.map-title{
    width: 500px;
    height: 80px;
}

.map-prev{
    width: 1000px;
    height: 610px;
}

.map-prev-tex{
    background-image: url('project:/Assets/Textures/map_prev_test.png');
    -unity-background-scale-mode: scale-to-fit;
}